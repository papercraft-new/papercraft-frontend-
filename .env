# ─────────────────────────────────────────
# PaperCraft AI — Frontend Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────

# API
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# App URL (used for metadata and OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Razorpay (public key only — never put secret here)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_SoO8qJqljdHIW2

# Google OAuth (client ID only)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
